# Папки збірки CMake (CLion зазвичай створює cmake-build-debug та ін.)
cmake-build-*/
build/
out/

# Налаштування середовища розробки CLion (.idea)
.idea/

# Специфічні файли користувача Qt Creator (на випадок, якщо колись відкриєш у ньому)
*.user

# Локальна база даних (ми не хочемо комітити тестові дані клієнтів у Git)
*.db
repairs.db

# Бінарні файли (якщо збірка відбудеться в корені)
*.exe
*.app
*.o
*.obj